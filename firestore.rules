rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /transactions/{docId} {
      // TODO: restrict to authenticated users once auth is added
      // allow read, write: if request.auth != null;
      allow read, write: if true;
    }
    // Legacy global collection — deny all access (data now lives under users/{uid})
    match /learnedMappings/{docId} {
      allow read, write: if false;
    }
    // Per-user learned mappings — only the owning user can read/write
    match /users/{userId}/learnedMappings/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Per-user learned income mappings
    match /users/{userId}/learnedIncomeMappings/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /uploaded_files/{docId} {
      allow read, write: if true;
    }
    match /additionalExpenses/{docId} {
      allow read, write: if true;
    }
    match /incomeTransactions/{docId} {
      allow read, write: if true;
    }
    match /incomeCategories/{docId} {
      allow read, write: if true;
    }
    match /categories/{docId} {
      allow read, write: if true;
    }
    match /pinnedBills/{docId} {
      allow read, write: if true;
    }
  }
}
